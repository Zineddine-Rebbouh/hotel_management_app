# MongoDB Connection
MONGO_DB_CONNECTION=mongodb://localhost:27017/hotel_management_app
# or for MongoDB Atlas:
# MONGO_DB_CONNECTION=mongodb+srv://username:password@cluster.mongodb.net/hotel_management_app

# Server Configuration
PORT=8000
NODE_ENV=development
PROJECT_STATUS=development

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars

# Stripe Payment (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLIC_KEY=pk_test_your_test_key_here

# Cloudinary Image Hosting (get from https://cloudinary.com/)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
